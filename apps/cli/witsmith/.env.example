# Witsmith — environment template
# Copy to .env and fill in values. Never commit .env.

# CLōD is the inference proxy that meters our team credits.
# It speaks the OpenAI /v1/chat/completions schema (NOT Anthropic /v1/messages).
# Endpoint + key live in docs/CLōD.md.
CLOD_API_KEY=clod-jwt-here
CLOD_BASE_URL=https://api.clod.io/v1

# Default model.
#
# FREE tier (no quota — use these for iteration):
#   gpt-oss-120b                        ← good general instruction-follower
#   gpt-oss-20b                         ← smaller / faster
#   qwen-3-235b-a22b-thinking-2507      ← reasoning model (emits <thinking> tokens)
#   deepseek-r1-0528-tput               ← reasoning, optimized throughput
#   glm-4-5-air                         ← efficient 106B
#   trinity-mini                        ← MoE, function-calling
#
# PREMIUM tier (consume team credits — use for the actual demo):
#   claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5
#   gpt-5, gpt-5-mini, gpt-5-nano
#   gemini-2-5-pro, gemini-2-5-flash, gemini-3-flash
#   grok-4
WITSMITH_MODEL=gpt-oss-120b

# Optional: model used only by `scripts/smoke_clod.py` (defaults to WITSMITH_MODEL).
# Set this to a free-tier id if your demo uses a premium WITSMITH_MODEL but smoke must stay free.
# WITSMITH_SMOKE_MODEL=gpt-oss-120b

# Where Witsmith writes runtime state inside the target repo.
WITSMITH_DIR=.witsmith

# Optional: override the markdown basename for `witsmith rescue --last` (no .md suffix).
# Default names are derived from source/command (e.g. recent-notes-deny.md, or
# 0042-smith-strikes-again.md when the command looks like a Prisma migrate).
# WITSMITH_HANDOFF_STEM=my-stage-quip

# Offline / quota-safe demos: skip live CLōD for NL + generic checks + amend/rescue.
# Unset or 0 when you have credits and want real model output.
# WITSMITH_MOCK_LLM=1
