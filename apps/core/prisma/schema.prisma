generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id           String   @id
  task         String
  repoPath     String
  branch       String
  baseCommit   String
  endCommit    String
  startedAt    DateTime
  finishedAt   DateTime
  status       String
  changedFiles String   // JSON array
  diff         String
  agentTrace   String
  rawBundle    String   // full EvidenceBundle JSON for reference

  memoryCards   MemoryCard[]
  sourceHashes  SourceFileHash[]

  createdAt DateTime @default(now())
}

model MemoryCard {
  id             String   @id
  sessionId      String
  session        Session  @relation(fields: [sessionId], references: [id])

  type           String   // episodic | semantic | procedural | risk
  claimType      String   // observed | agent_reported | inferred
  content        String
  evidence       String   // JSON array
  sourceFiles    String   // JSON array
  confidence     String   // low | medium | high
  retrieveWhen   String   // JSON array of keywords
  staleIfChanged String   // JSON array of file paths
  isStale        Boolean  @default(false)

  createdAt      DateTime
}

model LlmCache {
  id        String   @id @default(cuid())
  key       String   @unique  // SHA256 of model+prompt
  model     String
  response  String
  hitCount  Int      @default(0)
  createdAt DateTime @default(now())
  lastHitAt DateTime @default(now())
}

model SourceFileHash {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  filePath  String
  hash      String

  createdAt DateTime @default(now())

  @@unique([sessionId, filePath])
}
